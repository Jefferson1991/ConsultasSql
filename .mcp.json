{
  "mcpServers": {
    "hana-mcp-server-hana-empaqplast": {
      "command": "hana-mcp-server",
      "type": "stdio",
      "env": {
        "HANA_HOST": "erp.empaqplast.com",
        "HANA_PORT": "30015",
        "HANA_USER": "empaqplast",
        "HANA_PASSWORD": "Empaq2024.#!$%",
